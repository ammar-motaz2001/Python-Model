# Copy to .env and fill in values. Never commit .env (it is gitignored).

# MongoDB (Atlas example — use your cluster host and credentials)
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/soc_security?retryWrites=true&w=majority
MONGO_DB=soc_security

# Redis (optional; realtime + automation queue)
REDIS_URL=redis://localhost:6379/0

# CORS for browser frontends (comma-separated origins, or * for open API)
# CORS_ORIGINS=https://your-frontend.vercel.app
